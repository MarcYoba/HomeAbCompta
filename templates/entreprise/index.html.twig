                        <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 42px; height: 42px; background: #dcfce7; color: #166534;">
                            <i class="fas fa-check"></i>
                        </div>
                        <div>
                            <small class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem;">Ventes</small>
                            <div class="h4 mb-0 fw-bold">{{ nbvente }}</div>
                        </div>
                    </div>
