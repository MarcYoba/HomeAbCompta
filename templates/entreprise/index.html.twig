                        <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 42px; height: 42px; background: #fee2e2; color: #991b1b;">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <small class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem;">Dernière</small>
