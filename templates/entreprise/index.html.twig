                    <div>
                        <span class="display-5 fw-bold text-dark">1</span>
                        <span class="h3 text-muted">/{{ bd }}</span>
                    </div>
                    <div class="badge rounded-pill p-3" style="background: #e9f4ff; color: #0369a1; border: 1px solid rgba(2, 106, 162, 0.15);">
