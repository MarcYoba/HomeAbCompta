{% extends 'base.html.twig' %}

{% block title %}Entreprise!{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion | Votre Plateforme</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    {% include "navbar.html.twig" %}
    <div class="container">
        <div class="row min-vh-100 align-items-center justify-content-center">
            <div class="col-12 col-md-8 col-lg-5 col-xl-4 mt-5">
                
                <div class="card border-0 shadow-lg" style="border-radius: 1.5rem;">
                    <div class="card-body p-5">
                        
                        <div class="text-center mb-4">
                            <div class="bg-primary bg-gradient text-white d-inline-block p-3 rounded-circle mb-3 shadow">
                                <i class="fas fa-lock fa-2x"></i>
                            </div>
                            <h2 class="fw-bold">Bienvenue</h2>
                            <p class="text-muted">Connectez-vous à votre compte</p>
                        </div>

                        <form action="{{ path('app_entreprise_connexion_valider') }}" method="POST">
                            <div class="mb-3">
                                <label for="email" class="form-label small fw-bold text-uppercase">Adresse Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                                    <input type="email" class="form-control bg-light border-start-0" name="email" placeholder="nom@exemple.com" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <label for="password" class="form-label small fw-bold text-uppercase">Mot de passe</label>
                                    <a href="#" class="text-decoration-none small">Oublié ?</a>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-key text-muted"></i></span>
                                    <input type="password" class="form-control bg-light border-start-0" name="password" placeholder="••••••••" required>
                                </div>
                            </div>

                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="remember">
                                <label class="form-check-label small" for="remember">Rester connecté</label>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg shadow-sm" style="border-radius: 0.8rem;">
                                    Se connecter
                                </button>
                            </div>
                        </form>

                        {# <div class="text-center mt-4">
                            <p class="small text-muted mb-0">Vous n'avez pas de compte ?</p>
                            <a href="#" class="fw-bold text-decoration-none text-primary">Créer un compte</a>
                        </div> #}

                    </div>
                </div>

                <div class="text-center mt-4">
                    <a href="{{ path('index') }}" class="text-muted text-decoration-none small">
                        <i class="fas fa-arrow-left me-1"></i> Retour à l'accueil
                    </a>
                </div>

            </div>
        </div>
    </div>
    {% include "footer.html.twig" %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
{% endblock %}