{% extends 'base.html.twig' %}

{% block title %}Hello TransfertEntrepriseController!{% endblock %}

{% block body %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion | Votre Plateforme</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    {% include "navbar.html.twig" %}
    <div class="container">
        <div class="container mt-5">
            <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <!-- Nested Row within Card Body -->
                <div class="row">
                    <div class="col-lg-2 d-none d-lg-block bg-register-image">
                        
                    </div>
                    <div class="col-lg-12">
                        <div class="p-5">
                            <div class="text-center" >
                                <h1 class="h4 text-gray-900 mb-4">Rédaction du bon de transfert avec produit unique</h1>                            </div>
                            <div class="card-header py-3">
                                <div class="col-sm-6 mb-6 mb-sm-0">
                                    {% for message in app.flashes('success') %}
                                        <div class="alert alert-success">
                                            {{ message }}
                                        </div>
                                    {% endfor %}
                                </div>
                                
                            </div>
                            <form method="post" action="{{ path('app_transfert_entreprise_katanga') }}" class="user">
                                <div class="form-group row">
                                    <div class="col-sm-6">
                                        <p class="mb-1">
                                            <strong>N° de transfert :</strong>
                                            <input type="text" id="matricule" name="matricule" value="{{ matricule }}" class="form-control" readonly >
                                        </p>
                                    </div>
                                    <div class="col-sm-4">
                                        <p class="mb-1">Date : <strong>
                                        <input type="date" id="date" name="date" value="{{ "now" | date("d-m-Y") }}" class="form-control" required>
                                            </strong></p>
                                    </div>
                                    <div class="col-sm-4">
                                        <p class="mb-1">Magasin d'origine : <strong>
                                        <input type="text" id="direction" name="direction" value="{{ Agencedirection.nom ?? 'Magasin central' }}" class="form-control" readonly >
                                        </strong></p>
                                    </div>
                                    <div class="col-sm-4">
                                        <p class="mb-1"><strong>Destination :</strong> </p>
                                        <input type="text" id="agence" name="agence" value="{{AgenceKatang.nom ?? 'Production, vente, etc.' }}" class="form-control" readonly >
                                        
                                    </div>
                                    <div class="col-sm-4">
                                        <p class="mb-1">
                                            Demandé par employer : 
                                            <strong>
                                                <select id="employer" name="employer" class="form-control form-select" required>
                                                    {% for item in employers %}
                                                        <option value="{{ item.id }}">{{ item.nom }}</option>
                                                    {% endfor %}
                                                </select>
                                            </strong>
                                        </p>
                                    </div>
                                    <div class="col-sm-4">
                                        Produit a transferer : <strong> {{ Agencedirection.nom }} </strong>
                                        <input type="search" id="produitdirection" onkeyup="myFunction()"  class="form-control form-control-user" placeholder="Recherche du produit"><br>
                                        <select id="employer" name="produitdirection" id="produitdirection" class="form-control form-select" size="10"  multiple aria-label="multiple select" required>
                                            {% for item in produitdirestion %}
                                                <option value="{{ item.id }}">{{ item.nom }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-sm-4">
                                        Equivalent ou Produit : <strong> {{ AgenceKatang.nom }} </strong>
                                        <input type="search" id="produitkatng" onkeyup="Function()"  class="form-control form-control-user" placeholder="Recherche du produit"><br>
                                        <select id="employer" name="produitkatng" id="produitkatng" class="form-control form-select" size="10"  multiple aria-label="multiple select" required>
                                            {% for item in produitkatng %}
                                                <option value="{{ item.id }}">{{ item.nom }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-sm-4">
                                        Quantité
                                        <input type="text" id="quantite" name="produit" value="0" class="form-control" required>
                                    </div>
                                    <div class="col-sm-4">
                                        Approuvé par
                                        <select id="employer" name="employer" class="form-control form-select" required>
                                            {% for item in employerkatng %}
                                                <option value="{{ item.id }}">{{ item.nom }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <button type="submit" name="" value="Transféré" class="btn btn-primary btn-user btn-block">
                                    Transférer
                                </button>  
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div>
    </div>
    <script>
        function myFunction() {
            var input, filter, ul, li, a, i;
            input = document.getElementById("produitdirection");
            filter = input.value.toUpperCase();
            ul = document.getElementById("produitdirection");
            li = ul.getElementsByTagName("option");
            for (i = 0; i < li.length; i++) {
                a = li[i].textContent || li[i].innerText;
                if (a.toUpperCase().indexOf(filter) > -1) {
                    li[i].style.display = "";
                } else {
                    li[i].style.display = "none";
                }
            }
        }
    </script>
    {% include "footer.html.twig" %}

</body>
</html>
{% endblock %}